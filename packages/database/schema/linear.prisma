model LinearInstallation {
    id        String   @id @default(uuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    organizationId String       @unique
    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

    linearOrgId     String @unique // Linear workspace UUID
    linearOrgName   String
    linearOrgUrlKey String

    accessToken    String // ciphertext, AES-256-GCM via crypto.ts
    refreshToken   String? // ciphertext
    tokenScope     String
    tokenExpiresAt DateTime?

    installedById String?
    installedBy   Member? @relation(fields: [installedById], references: [id], onDelete: SetNull)

    projectLinks ProjectLinearLink[]

    @@index([organizationId])
    @@map("linear_installation")
}

model ProjectLinearLink {
    id        String   @id @default(uuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    projectId String  @unique
    project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

    linearInstallationId String
    linearInstallation   LinearInstallation @relation(fields: [linearInstallationId], references: [id], onDelete: Cascade)

    teamId   String
    teamKey  String
    teamName String

    autoCreateIssues Boolean  @default(true)
    defaultLabelIds  String[] @default([])
    defaultPriority  Int      @default(0)
    defaultStateId   String

    linkHealthIssue String? // null=healthy, "stale_default_state" | "stale_label" | "stale_team"

    feedbackIssueLinks FeedbackLinearIssueLink[]

    @@index([linearInstallationId])
    @@index([teamId])
    @@map("project_linear_link")
}

model FeedbackLinearIssueLink {
    id        String   @id @default(uuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    feedbackId String   @unique
    feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

    projectLinearLinkId String
    projectLinearLink   ProjectLinearLink @relation(fields: [projectLinearLinkId], references: [id], onDelete: Cascade)

    issueId         String
    issueIdentifier String
    issueUrl        String
    issueStateId    String
    issueStateType  String

    lastSyncSource String?
    lastSyncAt     DateTime?

    @@index([projectLinearLinkId])
    @@index([issueId])
    @@map("feedback_linear_issue_link")
}
